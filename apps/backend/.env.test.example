# คัดลอกเป็น apps/backend/.env.test แล้วปรับให้ตรงกับ Postgres/Redis ที่ใช้รัน E2E
# Migration ชุดเทส: จากโฟลเดอร์ backend รัน `yarn migration:run:test` (โหลด .env.test อัตโนมัติผ่าน SRIWILAI_DOTENV)
# ก่อนรัน E2E: สร้าง DB, start Redis, รัน migration ด้านบน

NODE_ENV=test
PORT=3099
APP_BASE_PATH=/api

# CORS (ว่างใน test = ใช้ค่าเริ่มต้นตาม configuration — development จำลอง)
# CORS_ORIGIN=

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=church_chord_pro
DB_PASSWORD=CHANGE_ME
DB_NAME=church_chord_pro_test
DB_SCHEMA=public
DB_SSL=false
DB_MAX_CONNECTIONS=10

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_OR_EMPTY
REDIS_DB=1
REDIS_TLS=false

LOG_LEVEL=error
LOG_PRETTY=false

AUTH_ACCESS_TOKEN_SECRET=test-access-secret-minimum-32-characters-long
AUTH_REFRESH_TOKEN_SECRET=test-refresh-secret-minimum-32-characters-long
AUTH_ACCESS_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_TOKEN_EXPIRES_IN_DAYS=30
AUTH_REFRESH_COOKIE_NAME=ccp_rt_test
AUTH_BCRYPT_SALT_ROUNDS=10

# ลด dependency ในเครื่องเทส: throttle แบบ in-memory (ค่าเป็น string ตาม .env)
THROTTLE_USE_REDIS=false
THROTTLE_TTL_MS=60000
THROTTLE_AUTH_REGISTER_LIMIT=100
THROTTLE_AUTH_LOGIN_LIMIT=100
THROTTLE_AUTH_REFRESH_LIMIT=100
THROTTLE_AUTH_LOGOUT_LIMIT=100

LIVE_WS_USE_REDIS_ADAPTER=false

TYPEORM_LOGGING=false
