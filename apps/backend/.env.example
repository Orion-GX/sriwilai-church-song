# Application
NODE_ENV=production
# พอร์ต API บนเครื่อง dev (แยกจาก Next.js ที่มักใช้ 3000)
PORT=3001
# รันเฉพาะ api ผ่าน apps/backend/docker-compose.yml: โฮสต์รับที่ API_HOST_PORT (ดีฟอลต์ 3001) → ใน container ยังฟัง 3000
# API_HOST_PORT=3001
APP_NAME=sriwilai-church-song-api
APP_VERSION=0.1.0
APP_BASE_PATH=/api

# CORS — คั่นหลาย origin ด้วย comma (ต้องตรงกับ URL ที่เปิด frontend)
# ว่างใน production = ปิด CORS ของ Nest (มักใช้เมื่อ reverse proxy same-origin)
# development default: http://localhost:3000 และ http://127.0.0.1:3000
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_USER=church_chord_pro
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=church_chord_pro
DB_SCHEMA=public
DB_SSL=false
DB_MAX_CONNECTIONS=20

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_DB=0
REDIS_TLS=false

# Logging
LOG_LEVEL=info
LOG_PRETTY=false

# Authentication
AUTH_ACCESS_TOKEN_SECRET=CHANGE_ME_ACCESS_SECRET_AT_LEAST_32_CHARS
AUTH_ACCESS_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_TOKEN_SECRET=CHANGE_ME_REFRESH_SECRET_AT_LEAST_32_CHARS
AUTH_REFRESH_TOKEN_EXPIRES_IN_DAYS=30
AUTH_REFRESH_COOKIE_NAME=ccp_rt
AUTH_BCRYPT_SALT_ROUNDS=12

# Rate limit (auth routes, @nestjs/throttler — ttl เป็นมิลลิวินาที)
# ใช้ Redis เป็น storage (แนะนำเมื่อรันหลาย replica / หลาย instance)
THROTTLE_USE_REDIS=true
THROTTLE_TTL_MS=60000
THROTTLE_AUTH_REGISTER_LIMIT=5
THROTTLE_AUTH_LOGIN_LIMIT=10
THROTTLE_AUTH_REFRESH_LIMIT=30
THROTTLE_AUTH_LOGOUT_LIMIT=60

# Socket.IO /live namespace — Redis adapter เมื่อรันหลาย instance (ค่าเดียวกับ REDIS_*)
LIVE_WS_USE_REDIS_ADAPTER=false

# TypeORM CLI (migration) — เปิด true เมื่อดีบัก migration
TYPEORM_LOGGING=false
