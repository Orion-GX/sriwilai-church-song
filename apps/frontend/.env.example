# --- โหมด A: เรียก Nest ตรง (คนละพอร์ต) ต้องตั้ง CORS ที่ backend ให้ตรง origin นี้
# NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# NEXT_PUBLIC_WS_ORIGIN=http://localhost:3001

# --- โหมด B: Next.js reverse proxy (same-origin, cookie refresh ง่ายขึ้น)
# BACKEND_INTERNAL_URL=http://127.0.0.1:3001
# NEXT_PUBLIC_API_URL=/api/v1
# Socket ยังต่อไปที่ Nest โดยตรง (ไม่ผ่าน Next)
# NEXT_PUBLIC_WS_ORIGIN=http://localhost:3001

NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_ORIGIN=http://localhost:3001
