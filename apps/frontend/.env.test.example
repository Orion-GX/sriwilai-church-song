# คัดลอกเป็น `apps/frontend/.env.test` (ไม่ commit) — โหลดโดย `playwright.config.ts` อัตโนมัติ
#
# URL ที่ Playwright เปิดเบราว์เซอร์ (ต้องตรงกับ `yarn dev` หรือเซิร์ฟเวอร์ที่รันอยู่)
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# ถ้า dev server รันอยู่แล้ว — ปิดการสตาร์ทซ้ำใน Playwright
# PLAYWRIGHT_NO_WEB_SERVER=1

# ใช้ `yarn start` แทน `yarn dev` ใน webServer (ต้อง `yarn build` ก่อน)
# PLAYWRIGHT_USE_PROD_SERVER=1

# --- ใช้กับ helper `apiLogin` (optional) เมื่อต้องการล็อกอินผ่าน Nest โดยไม่กรอกฟอร์ม
# ต้องตรงกับฐานที่ frontend เรียก (โหมด dev:stack ใช้พอร์ต 3099 — ดู `yarn dev:stack` ที่รากโปรเจกต์)
E2E_API_BASE_URL=http://127.0.0.1:3099/api/v1

# บัญชีทดสอบที่มีอยู่บน backend (สร้างล่วงหน้าด้วย register หรือ `yarn seed:e2e` — ดู docs/e2e-seed.md)
E2E_USER_EMAIL=playwright-smoke@example.test
E2E_USER_PASSWORD=Playwright_smoke_1!

# ค่าด้านล่างตรงกับ `e2e-seed.config.json` + `yarn seed:e2e` (รหัสเดียวกันทุกบทบาท)
# E2E_SONG_EDITOR_EMAIL=e2e-song-editor@example.test
# E2E_SONG_EDITOR_PASSWORD=Playwright_seed_e2e_1!
# E2E_ADMIN_EMAIL=e2e-admin@example.test
# E2E_ADMIN_PASSWORD=Playwright_seed_e2e_1!
# E2E_LIVE_LEADER_EMAIL=e2e-live-leader@example.test
# E2E_LIVE_LEADER_PASSWORD=Playwright_seed_e2e_1!
# E2E_LIVE_FOLLOWER_EMAIL=e2e-live-follower@example.test
# E2E_LIVE_FOLLOWER_PASSWORD=Playwright_seed_e2e_1!
