# Copy this file to .env.ngrok (kept local, never commit token):
# cp .env.ngrok.example .env.ngrok

# Required: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=REPLACE_WITH_YOUR_NGROK_AUTHTOKEN

# Example 1 (simple HTTP command mode):
# - Host app (Mac/Windows): http://host.docker.internal:3000
# - Host app (Linux): same hostname works when extra_hosts host-gateway is enabled in compose.
# - Containerized app in same compose project: e.g. http://web:3000 or http://nginx:80
NGROK_TARGET=http://host.docker.internal:3000

# Optional reserved domain (only if your ngrok plan supports it).
# For command mode, you can manually add --domain if needed.
NGROK_DOMAIN=
