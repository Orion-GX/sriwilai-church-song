{
  "name": "sriwilai-church-song-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for Sriwilai Church Song",
  "license": "UNLICENSED",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest --config jest.config.cjs",
    "test:e2e": "jest --config ./test/jest-e2e.config.cjs --runInBand",
    "test:cov": "jest --config jest.config.cjs --coverage",
    "migration:run": "typeorm-ts-node-commonjs -d src/infrastructure/database/data-source.ts migration:run",
    "migration:run:test": "cross-env SRIWILAI_DOTENV=.env.test typeorm-ts-node-commonjs -d src/infrastructure/database/data-source.ts migration:run",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d dist/infrastructure/database/data-source.js",
    "migration:revert": "typeorm-ts-node-commonjs -d src/infrastructure/database/data-source.ts migration:revert",
    "migration:revert:test": "cross-env SRIWILAI_DOTENV=.env.test typeorm-ts-node-commonjs -d src/infrastructure/database/data-source.ts migration:revert",
    "migration:show": "typeorm-ts-node-commonjs -d src/infrastructure/database/data-source.ts migration:show",
    "migration:show:test": "cross-env SRIWILAI_DOTENV=.env.test typeorm-ts-node-commonjs -d src/infrastructure/database/data-source.ts migration:show"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.15",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "joi": "^17.13.3",
    "nestjs-pino": "^4.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "pino": "^8.21.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "socket.io-adapter": "^2.5.5",
    "typeorm": "^0.3.26"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.3",
    "prettier": "^3.6.2",
    "socket.io-client": "4.8.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
  }
}
