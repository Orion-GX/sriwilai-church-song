# ================================
# Docker Compose (คัดลอกเป็น .env)
# cp .env.example .env
# ================================

# พอร์ตที่ Nginx เปิดบนเครื่อง host
HTTP_PORT=80

# --- Dev บนเครื่อง (ไม่ใช้ Docker) ---
# Next.js: npm run dev → พอร์ต 3000 (frontend/package.json)
# Nest API: ตั้ง PORT=3001 ใน backend/.env (backend/.env.example)

# --- PostgreSQL ---
DB_NAME=church_chord_pro
DB_USER=church_chord_pro
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# --- JWT (อย่างน้อย 32 ตัวอักษร ต่อ secret) ---
AUTH_ACCESS_TOKEN_SECRET=CHANGE_ME_ACCESS_SECRET_AT_LEAST_32_CHARACTERS
AUTH_REFRESH_TOKEN_SECRET=CHANGE_ME_REFRESH_SECRET_AT_LEAST_32_CHARACTERS
AUTH_ACCESS_TOKEN_EXPIRES_IN=15m
AUTH_REFRESH_TOKEN_EXPIRES_IN_DAYS=30
AUTH_REFRESH_COOKIE_NAME=ccp_rt
AUTH_BCRYPT_SALT_ROUNDS=12

# --- CORS: origin ที่ผู้ใช้เปิดเว็บ (ต้องตรง scheme+host+port) ---
# ตัวอย่างหลัง reverse proxy ที่ port 80: http://localhost
CORS_ORIGIN=http://localhost

# --- ตัวแปรฝัง frontend ตอน build (docker compose build web) ---
# same-origin ผ่าน Nginx — ใช้ path นี้
NEXT_PUBLIC_API_URL=/api/v1
# ว่าง = Socket.IO ไปที่ origin เดียวกับหน้าเว็บ (แนะนำเมื่อมี Nginx หน้าเดียว)
NEXT_PUBLIC_WS_ORIGIN=

# --- ออปชัน ---
DB_SCHEMA=public
LOG_LEVEL=info
THROTTLE_USE_REDIS=true
LIVE_WS_USE_REDIS_ADAPTER=false

# ================================
# คำสั่งรันทั่วไป
# ================================
# docker compose build
# docker compose up -d
# docker compose ps
# docker compose logs -f nginx api web
#
# migration ครั้งแรก / หลัง deploy:
# docker compose exec api yarn migration:run:prod
#
# หยุด:
# docker compose down
#
# health (จาก host):
# curl -s http://localhost/api/v1/health | jq
# curl -s http://localhost/nginx-health
