# คัดลอกเป็น `frontend/.env.test` (ไม่ commit) — โหลดโดย `playwright.config.ts` อัตโนมัติ
#
# URL ที่ Playwright เปิดเบราว์เซอร์ (ต้องตรงกับ `yarn dev` หรือเซิร์ฟเวอร์ที่รันอยู่)
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# ถ้า dev server รันอยู่แล้ว — ปิดการสตาร์ทซ้ำใน Playwright
# PLAYWRIGHT_NO_WEB_SERVER=1

# ใช้ `yarn start` แทน `yarn dev` ใน webServer (ต้อง `yarn build` ก่อน)
# PLAYWRIGHT_USE_PROD_SERVER=1

# --- ใช้กับ helper `apiLogin` (optional) เมื่อต้องการล็อกอินผ่าน Nest โดยไม่กรอกฟอร์ม
# ต้องตรงกับฐานที่ frontend เรียก (โหมดตรงพอร์ต / ผ่าน reverse proxy)
E2E_API_BASE_URL=http://127.0.0.1:3001/api/v1

# บัญชีทดสอบที่มีอยู่บน backend (สร้างล่วงหน้าด้วย register หรือ seed)
E2E_USER_EMAIL=playwright-smoke@example.test
E2E_USER_PASSWORD=Playwright_smoke_1!

# สำหรับ `tests/e2e/songs.spec.ts` — สร้าง/แก้ไขเพลงผ่าน API (ต้องมี song.create + song.update แบบ global เช่น system_admin)
# E2E_SONG_EDITOR_EMAIL=admin-e2e@example.test
# E2E_SONG_EDITOR_PASSWORD=Your_Strong_Password

# สำหรับ `tests/e2e/admin.spec.ts` — ต้องมีสิทธิ์ system.admin (role system_admin แบบ global ในฐาน)
# E2E_ADMIN_EMAIL=playwright-admin@example.test
# E2E_ADMIN_PASSWORD=Your_Strong_Password
